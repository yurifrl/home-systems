{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "argocd": {
    "managerFilePatterns": [
      "/k8s/applications/.+\\.yaml$/"
    ]
  },
  "enabledManagers": ["argocd", "github-actions", "helm-values", "custom.regex"],
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "packageRules": [
    {
      "description": "Auto-merge Hermes image base (python) and app (hermes-agent) bumps",
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["k8s/images/hermes/Dockerfile"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Longhorn does not support skip-version minor upgrades (1.8.1 -> 1.12.0 broke the cluster on 2026-06-03). Restrict to patch bumps so a minor walk has to be done deliberately, one version at a time.",
      "matchManagers": ["argocd"],
      "matchPackageNames": ["longhorn"],
      "matchUpdateTypes": ["major", "minor"],
      "enabled": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/k8s/images/.+/Dockerfile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) versioning=(?<versioning>\\S+)\\s+ARG \\w+_VERSION=(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "{{{datasource}}}",
      "depNameTemplate": "{{{depName}}}",
      "versioningTemplate": "{{{versioning}}}"
    }
  ]
}
