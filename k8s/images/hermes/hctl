#!/usr/bin/env python3
"""hctl — in-container helper CLI for the Hermes image.

Replaces the long inline shell blobs that used to live in the Helm chart's
init/sidecar containers. Subcommands:

  hctl auth login
      gh auth login + setup-git using GH_TOKEN/GITHUB_TOKEN from the
      hermes-env secret. Persists credentials to $HOME so subsequent git
      pushes work. Idempotent. Soft-skips when no token is set.

  hctl op files sync
      Download every file attachment of a 1Password item via the Connect
      REST API into a directory. Dynamic by design — no filenames are
      configured. Equivalent to the legacy `op-files-sync` script. Soft-
      skips when env is incomplete.

  hctl repos clone --user U --repos a,b,c [--dest /workdir]
      Clone every <user>/<name> repo into <dest>/<name> if absent. Idempotent.

  hctl repos sync --dir /workdir [--interval 1h]
      Long-running loop. Every <interval>, for each repo in <dir>:
        git pull --rebase --autostash
        git add -A; commit if dirty
        git push if ahead
      On SIGTERM/SIGINT runs ONE final cycle (the "on-exit backup commit")
      then exits 0. Exits 1 (crash-loop) on push failure mid-loop so the
      failure surfaces in pod status.

CLIENT subcommands (local machine, need kubectl + a working kubeconfig):

  hctl exec [args...]
      Run the `hermes` CLI inside the hermes-0 pod.

  hctl bash
      Open an interactive bash shell in the hermes-0 pod.

  hctl status
      Table of every hermes pod (phase, ready, restarts, age, note). Pure
      observability — no side effects, no AI.

  hctl doctor [text]
      Open a pi session to diagnose AND fix hermes (an active flow — it will
      change cluster/repo state). With text, that's the lead symptom. Without
      text, scans the pods and, only if something's broken, builds a layered
      prompt from what's actually failing.

  hctl refresh
      Delete the hermes-env secret (ExternalSecret recreates it), restart
      the statefulset, and watch until ready.

  hctl client backup
      Snapshot the state volume and push it off-cluster to the Longhorn
      backup target now, instead of waiting for the daily 02:00 job. Blocks
      until the backup reports Completed.

All subcommands are stdlib-only — the image base has python3, git, gh.
"""
from __future__ import annotations

import argparse
import datetime
import json
import os
import shutil
import signal
import subprocess
import sys
import time
import urllib.parse
import urllib.request
from pathlib import Path


# ─────────────────────────────────────── helpers ──

def _env(name: str, default: str = "") -> str:
    return os.environ.get(name, default).strip()


def _run(cmd: list[str], cwd: str | None = None, check: bool = True,
         capture: bool = False) -> subprocess.CompletedProcess:
    """Thin subprocess.run wrapper that always inherits stdio unless capture."""
    kwargs: dict = {"cwd": cwd}
    if capture:
        kwargs["capture_output"] = True
        kwargs["text"] = True
    return subprocess.run(cmd, check=check, **kwargs)


def _parse_duration(s: str) -> int:
    """Parse '30s', '5m', '1h', '2d' → seconds. Bare integers are seconds."""
    s = s.strip().lower()
    if not s:
        raise ValueError("empty duration")
    if s[-1] in ("s", "m", "h", "d"):
        n = int(s[:-1])
        return n * {"s": 1, "m": 60, "h": 3600, "d": 86400}[s[-1]]
    return int(s)


def _log(msg: str) -> None:
    print(f"hctl: {msg}", flush=True)


def _err(msg: str) -> None:
    print(f"hctl: {msg}", file=sys.stderr, flush=True)


# ─────────────────────────────────────── auth login ──

def cmd_auth_login(_args) -> int:
    """Authenticate gh + git from $GH_TOKEN/$GITHUB_TOKEN, persist creds to $HOME."""
    home = _env("HOME") or "/opt/data/home"
    os.environ["HOME"] = home
    Path(home, ".config", "gh").mkdir(parents=True, exist_ok=True)

    token = _env("GH_TOKEN") or _env("GITHUB_TOKEN")
    if not token:
        _err("auth login: no GH_TOKEN/GITHUB_TOKEN; skipping")
        return 0

    # gh refuses to persist creds while GH_TOKEN/GITHUB_TOKEN is set in env.
    for v in ("GH_TOKEN", "GITHUB_TOKEN"):
        os.environ.pop(v, None)

    # Stream token via stdin so it never lands in argv.
    subprocess.run(
        ["gh", "auth", "login", "--with-token"],
        input=token, text=True, check=True,
    )

    _run(["gh", "auth", "setup-git"])

    name = _env("GIT_AUTHOR_NAME")
    email = _env("GIT_AUTHOR_EMAIL")
    if name:
        _run(["git", "config", "--global", "user.name", name])
    if email:
        _run(["git", "config", "--global", "user.email", email])

    _run(["gh", "auth", "status"])
    return 0


# ─────────────────────────────────────── op files sync ──

def cmd_op_files_sync(args) -> int:
    """Download every file attachment of a 1Password item via Connect REST API.

    Config resolution order (first non-empty wins):
      flag  >  env
    Token can come from:
      --token              (literal; testing only)
      --token-file PATH    (mounted secret)
      --connect-credentials-secret NS/NAME[:KEY]
                           (kubectl get secret … -o jsonpath; KEY default 'token')
      OP_CONNECT_TOKEN env (fallback)
    """
    host = (args.host or _env("OP_CONNECT_HOST")).rstrip("/")
    vault = args.vault or _env("OP_VAULT")
    item = args.item or _env("OP_ITEM")
    dest = args.dest or _env("OP_DEST")

    token = (args.token or "").strip()
    if not token and args.token_file:
        try:
            token = Path(args.token_file).read_text().strip()
        except FileNotFoundError:
            _err(f"op files sync: token file {args.token_file} not found")
            return 0
    if not token and args.connect_credentials_secret:
        ref = args.connect_credentials_secret
        key = "token"
        if ":" in ref:
            ref, key = ref.rsplit(":", 1)
        if "/" not in ref:
            _err("op files sync: --connect-credentials-secret must be NS/NAME[:KEY]")
            return 10
        ns, name = ref.split("/", 1)
        try:
            out = _run(
                ["kubectl", "get", "secret", "-n", ns, name,
                 "-o", f"jsonpath={{.data.{key}}}"],
                capture=True, check=True,
            ).stdout.strip()
            import base64
            token = base64.b64decode(out).decode().strip() if out else ""
        except subprocess.CalledProcessError as e:
            _err(f"op files sync: kubectl get secret failed: {e}")
            return 0
    if not token:
        token = _env("OP_CONNECT_TOKEN")

    if not all([host, vault, item, dest]):
        _err("op files sync: missing host/vault/item/dest; skipping")
        return 0
    if not token:
        _err("op files sync: no token available; skipping")
        return 0

    def get(path: str, raw: bool = False):
        req = urllib.request.Request(host + path, headers={"Authorization": "Bearer " + token})
        data = urllib.request.urlopen(req, timeout=20).read()
        return data if raw else json.loads(data)

    vaults = get("/v1/vaults")
    vid = next((v["id"] for v in vaults if v.get("name") == vault), None)
    if not vid:
        _err(f"op files sync: vault {vault!r} not found; skipping")
        return 0

    q = urllib.parse.quote(f'title eq "{item}"')
    items = get(f"/v1/vaults/{vid}/items?filter={q}")
    if not items:
        _err(f"op files sync: item {item!r} not found in vault {vault!r}; skipping")
        return 0
    iid = items[0]["id"]

    full = get(f"/v1/vaults/{vid}/items/{iid}")
    files = full.get("files", []) or []

    os.makedirs(dest, exist_ok=True)
    written = 0
    for f in files:
        name = os.path.basename(f.get("name", "")).strip()
        if not name:
            continue
        cp = f.get("content_path") or f"/v1/vaults/{vid}/items/{iid}/files/{f['id']}/content"
        blob = get(cp, raw=True)
        out = os.path.join(dest, name)
        with open(out, "wb") as fh:
            fh.write(blob)
        os.chmod(out, 0o600)
        _log(f"op files sync: wrote {name} ({len(blob)} bytes)")
        written += 1

    _log(f"op files sync: done, {written} file(s) from item {item!r}")
    return 0


# ─────────────────────────────────────── repos clone ──

def _parse_repos(spec: str) -> list[str]:
    return [r.strip() for r in spec.split(",") if r.strip()]


def _parse_repo_spec(spec: str) -> tuple[str, str]:
    """Parse 'name' or 'name@branch' into (name, branch). Empty branch = default."""
    if "@" in spec:
        name, branch = spec.rsplit("@", 1)
        return name.strip(), branch.strip()
    return spec.strip(), ""


def _reconcile_branch(repo_dir: str, branch: str) -> None:
    """Ensure repo is on the expected branch. Fetches and switches if needed."""
    if not branch:
        return
    current = _run(
        ["git", "rev-parse", "--abbrev-ref", "HEAD"],
        cwd=repo_dir, capture=True, check=True,
    ).stdout.strip()
    if current == branch:
        return
    _log(f"repos clone: {os.path.basename(repo_dir)} on {current!r}, switching to {branch!r}")
    _run(["git", "fetch", "origin"], cwd=repo_dir)
    _run(["git", "checkout", branch], cwd=repo_dir, check=False)
    _run(["git", "branch", f"--set-upstream-to=origin/{branch}", branch], cwd=repo_dir, check=False)


def cmd_repos_clone(args) -> int:
    """Clone <user>/<name> for each name in --repos into <dest>/<name>.

    Repos can be specified as 'name' or 'name@branch'. Default branch is
    controlled by --branch (defaults to 'main'). If the repo already exists,
    reconciles: ensures it's on the expected branch.
    """
    user = args.user.strip()
    repos = _parse_repos(args.repos)
    dest = args.dest
    default_branch = args.branch

    if not user:
        _err("repos clone: --user is required")
        return 10
    if not repos:
        _log("repos clone: no repos configured; skipping")
        return 0

    os.makedirs(dest, exist_ok=True)
    for spec in repos:
        name, branch = _parse_repo_spec(spec)
        branch = branch or default_branch
        target = os.path.join(dest, name)
        url = f"https://github.com/{user}/{name}.git"
        if os.path.isdir(os.path.join(target, ".git")):
            _log(f"repos clone: {target} already present")
            _reconcile_branch(target, branch)
            continue
        _log(f"repos clone: cloning {url} -> {target} (branch: {branch})")
        _run(["git", "clone", "--branch", branch, url, target])
    return 0


# ─────────────────────────────────────── repos sync ──

class _StopSignal(Exception):
    """Raised inside the sync loop when SIGTERM/SIGINT is received."""


def _list_repos(root: str) -> list[str]:
    try:
        names = sorted(os.listdir(root))
    except FileNotFoundError:
        return []
    out = []
    for name in names:
        if os.path.isdir(os.path.join(root, name, ".git")):
            out.append(name)
    return out


def _sync_one(repo_dir: str) -> None:
    """One pull/commit/push pass for a single repo. Raises on push failure."""
    name = os.path.basename(repo_dir)

    # Ensure upstream tracking is set before pulling.
    tracking = _run(
        ["git", "rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{u}"],
        cwd=repo_dir, capture=True, check=False,
    )
    if tracking.returncode != 0:
        branch = _run(
            ["git", "rev-parse", "--abbrev-ref", "HEAD"],
            cwd=repo_dir, capture=True, check=True,
        ).stdout.strip()
        _log(f"sync: {name} — no upstream, setting to origin/{branch}")
        _run(["git", "branch", f"--set-upstream-to=origin/{branch}", branch],
             cwd=repo_dir, check=False)

    _log(f"sync: {name} — pull")
    rc = subprocess.run(
        ["git", "pull", "--rebase", "--autostash"],
        cwd=repo_dir,
    ).returncode
    if rc != 0:
        raise RuntimeError(f"pull failed for {name}")

    subprocess.run(["git", "add", "-A"], cwd=repo_dir, check=True)

    diff = subprocess.run(
        ["git", "diff", "--cached", "--quiet"],
        cwd=repo_dir,
    ).returncode
    if diff != 0:
        author = _env("GIT_AUTHOR_NAME") or "hermes"
        email = _env("GIT_AUTHOR_EMAIL") or "hermes@local"
        ts = time.strftime("%Y-%m-%dT%H:%M:%S%z")
        _log(f"sync: {name} — commit")
        subprocess.run(
            [
                "git",
                "-c", f"user.name={author}",
                "-c", f"user.email={email}",
                "commit", "-m", f"auto: {ts}",
            ],
            cwd=repo_dir, check=True,
        )

    status = subprocess.run(
        ["git", "status", "-sb"],
        cwd=repo_dir, capture_output=True, text=True, check=True,
    ).stdout
    if "[ahead" in status:
        _log(f"sync: {name} — push")
        rc = subprocess.run(["git", "push"], cwd=repo_dir).returncode
        if rc != 0:
            raise RuntimeError(f"push failed for {name}")


def _sync_pass(root: str) -> None:
    """One full pass over every repo under <root>. Stops on first failure."""
    for name in _list_repos(root):
        _sync_one(os.path.join(root, name))


def cmd_repos_sync(args) -> int:
    """Periodic + on-exit commit+push loop. SIGTERM/SIGINT runs final pass."""
    root = args.dir
    interval_s = _parse_duration(args.interval)
    _log(f"repos sync: dir={root} interval={interval_s}s")

    stop = {"flag": False}

    def _handler(signum, _frame):
        _log(f"repos sync: caught signal {signum}; will run final pass and exit")
        stop["flag"] = True

    signal.signal(signal.SIGTERM, _handler)
    signal.signal(signal.SIGINT, _handler)

    while not stop["flag"]:
        try:
            _sync_pass(root)
        except RuntimeError as e:
            _err(f"repos sync: {e}")
            return 1
        # Sleep in 1s slices so SIGTERM is responsive.
        for _ in range(interval_s):
            if stop["flag"]:
                break
            time.sleep(1)

    # Final pass on the way out.
    _log("repos sync: final pass before exit")
    try:
        _sync_pass(root)
    except RuntimeError as e:
        _err(f"repos sync: final pass failed: {e}")
        return 1
    return 0


# ─────────────────────────────────────── backup ──
#
# Curated, secret-free git backup of HERMES_HOME. Only an allowlist of durable
# paths is mirrored into a private repo; everything else (secrets, live SQLite
# DBs, caches, sessions) stays out of git and is covered by the volume snapshot.
# The .gitignore is fail-closed (`*` + `!<allowlist>`) so a stray copy can never
# commit an unexpected file.

_BACKUP_FILES = ["SOUL.md", "config.yaml"]
_BACKUP_DIRS = ["memories", "skills", "cron"]


def _write_backup_gitignore(repo_dir: str) -> None:
    lines = ["# managed by `hctl backup` — fail-closed allowlist", "*", "!.gitignore", "!README.md"]
    for f in _BACKUP_FILES:
        lines.append(f"!{f}")
    for d in _BACKUP_DIRS:
        lines.append(f"!{d}/")
        lines.append(f"!{d}/**")
    Path(repo_dir, ".gitignore").write_text("\n".join(lines) + "\n")


def _mirror_allowlist(home: str, repo_dir: str) -> None:
    """Copy the allowlisted paths from HERMES_HOME into the repo, mirroring deletes."""
    for f in _BACKUP_FILES:
        src, dst = Path(home, f), Path(repo_dir, f)
        if src.is_file():
            shutil.copy2(src, dst)
        elif dst.exists():
            dst.unlink()
    for d in _BACKUP_DIRS:
        src, dst = Path(home, d), Path(repo_dir, d)
        if dst.exists():
            shutil.rmtree(dst)
        if src.is_dir():
            shutil.copytree(src, dst)


def _backup_pass(home: str, repo_dir: str, branch: str) -> None:
    """One mirror/commit/push pass. Raises on push failure."""
    _write_backup_gitignore(repo_dir)
    _mirror_allowlist(home, repo_dir)

    # On a freshly cloned empty repo HEAD is unborn — create the branch.
    unborn = _run(["git", "rev-parse", "--verify", "HEAD"],
                  cwd=repo_dir, check=False, capture=True).returncode != 0
    if unborn:
        _run(["git", "checkout", "-b", branch], cwd=repo_dir, check=False)

    _run(["git", "add", "-A"], cwd=repo_dir)
    dirty = _run(["git", "diff", "--cached", "--quiet"],
                 cwd=repo_dir, check=False).returncode != 0
    if not dirty:
        return

    author = _env("GIT_AUTHOR_NAME") or "hermes"
    email = _env("GIT_AUTHOR_EMAIL") or "hermes@local"
    ts = time.strftime("%Y-%m-%dT%H:%M:%S%z")
    _log("backup: commit")
    _run(["git", "-c", f"user.name={author}", "-c", f"user.email={email}",
          "commit", "-m", f"backup: {ts}"], cwd=repo_dir)

    _log("backup: push")
    rc = _run(["git", "push", "-u", "origin", branch], cwd=repo_dir, check=False).returncode
    if rc != 0:
        # Remote moved (shouldn't happen with one writer) — rebase and retry once.
        _run(["git", "pull", "--rebase", "--autostash", "origin", branch],
             cwd=repo_dir, check=False)
        rc = _run(["git", "push", "-u", "origin", branch], cwd=repo_dir, check=False).returncode
        if rc != 0:
            raise RuntimeError("backup push failed")


def cmd_backup(args) -> int:
    """Periodic + on-exit git backup of the HERMES_HOME allowlist. SIGTERM = final pass."""
    home = args.home or _env("HERMES_HOME") or "/opt/data"
    user = args.user.strip()
    repo = args.repo.strip()
    branch = args.branch or "main"
    dest = args.dest
    interval_s = _parse_duration(args.interval)

    if not user:
        _err("backup: --user is required")
        return 10
    if not repo:
        _err("backup: --repo is required")
        return 10

    repo_dir = os.path.join(dest, repo)
    url = f"https://github.com/{user}/{repo}.git"
    os.makedirs(dest, exist_ok=True)
    if not os.path.isdir(os.path.join(repo_dir, ".git")):
        _log(f"backup: cloning {url} -> {repo_dir}")
        _run(["git", "clone", url, repo_dir], check=False)
    else:
        _reconcile_branch(repo_dir, branch)

    _log(f"backup: home={home} repo={user}/{repo} branch={branch} interval={interval_s}s")

    stop = {"flag": False}

    def _handler(signum, _frame):
        _log(f"backup: caught signal {signum}; will run final pass and exit")
        stop["flag"] = True

    signal.signal(signal.SIGTERM, _handler)
    signal.signal(signal.SIGINT, _handler)

    while not stop["flag"]:
        try:
            _backup_pass(home, repo_dir, branch)
        except RuntimeError as e:
            _err(f"backup: {e}")
            return 1
        for _ in range(interval_s):
            if stop["flag"]:
                break
            time.sleep(1)

    _log("backup: final pass before exit")
    try:
        _backup_pass(home, repo_dir, branch)
    except RuntimeError as e:
        _err(f"backup: final pass failed: {e}")
        return 1
    return 0


def cmd_restore(args) -> int:
    """Seed a fresh HERMES_HOME from the backup repo, but only if it's empty.

    Guard: restore only when the allowlisted `memories/` dir is absent. Never
    overwrites a populated live volume.
    """
    home = args.home or _env("HERMES_HOME") or "/opt/data"
    user = args.user.strip()
    repo = args.repo.strip()
    branch = args.branch or "main"
    dest = args.dest

    if Path(home, "memories").exists():
        _log("restore: memories/ already present; skipping")
        return 0

    repo_dir = os.path.join(dest, repo)
    url = f"https://github.com/{user}/{repo}.git"
    os.makedirs(dest, exist_ok=True)
    if not os.path.isdir(os.path.join(repo_dir, ".git")):
        _log(f"restore: cloning {url} -> {repo_dir}")
        _run(["git", "clone", "--branch", branch, url, repo_dir], check=False)

    if not os.path.isdir(os.path.join(repo_dir, ".git")):
        _err("restore: clone failed; skipping")
        return 0

    for f in _BACKUP_FILES:
        src = Path(repo_dir, f)
        if src.is_file():
            _log(f"restore: {f}")
            shutil.copy2(src, Path(home, f))
    for d in _BACKUP_DIRS:
        src = Path(repo_dir, d)
        if src.is_dir():
            _log(f"restore: {d}/")
            shutil.copytree(src, Path(home, d), dirs_exist_ok=True)
    return 0


# ─────────────────────────────────────── client (local machine) ──
#
# These run on your laptop and talk to the pod over kubectl. Defaults match the
# hermes statefulset; override via env if the deploy names ever change.

_NS = _env("HERMES_NS") or "hermes"
_SECRET = _env("HERMES_SECRET") or "hermes-env"
_STS = _env("HERMES_STS") or "hermes"
_CONTAINER = _env("HERMES_CONTAINER") or "hermes-agent"
_POD = f"{_STS}-0"
# State PVC holding /opt/data (creds, sessions, memories) — the volume worth backing up.
_STATE_PVC = _env("HERMES_STATE_PVC") or f"state-{_STS}-0"


def cmd_exec(args) -> int:
    """Run the `hermes` CLI inside the pod."""
    return subprocess.run(
        ["kubectl", "exec", "-it", _POD, "-n", _NS, "-c", _CONTAINER,
         "--", "hermes", *args.args],
    ).returncode


def cmd_bash(_args) -> int:
    """Open an interactive bash shell in the pod."""
    _log(f"opening bash shell in {_POD} ({_NS})")
    return subprocess.run(
        ["kubectl", "exec", "-it", _POD, "-n", _NS, "-c", _CONTAINER,
         "--", "/bin/bash"],
    ).returncode


def _age(ts: str) -> str:
    """RFC3339 timestamp → human age like '3m', '2h4m', '5d'."""
    if not ts:
        return "?"
    started = datetime.datetime.strptime(ts, "%Y-%m-%dT%H:%M:%SZ").replace(
        tzinfo=datetime.timezone.utc)
    secs = int((datetime.datetime.now(datetime.timezone.utc) - started).total_seconds())
    d, secs = divmod(secs, 86400)
    h, secs = divmod(secs, 3600)
    m, _ = divmod(secs, 60)
    if d:
        return f"{d}d{h}h"
    if h:
        return f"{h}h{m}m"
    return f"{m}m"


def _pod_summary(pod: dict) -> tuple[str, str, int, str]:
    """→ (phase, ready 'n/m', restarts, reason). reason explains not-ready pods."""
    st = pod.get("status", {})
    phase = st.get("phase", "?")
    cs = st.get("containerStatuses", []) or []
    ready = sum(1 for c in cs if c.get("ready"))
    restarts = sum(c.get("restartCount", 0) for c in cs)
    # Blocking init container or waiting app container = why it's not up yet.
    reason = ""
    for c in (st.get("initContainerStatuses", []) or []):
        if not c.get("ready"):
            w = c.get("state", {}).get("waiting") or c.get("state", {}).get("running")
            reason = f"init {c['name']}: {(w or {}).get('reason', 'running')}"
            break
    if not reason:
        for c in cs:
            w = c.get("state", {}).get("waiting")
            if w:
                reason = f"{c['name']}: {w.get('reason', '')}"
                break
    return phase, f"{ready}/{len(cs)}", restarts, reason


def _failing_containers(pod: dict) -> list[str]:
    """Names of init/app containers that aren't ready (candidates for log pulls)."""
    st = pod.get("status", {})
    names = []
    for c in (st.get("initContainerStatuses", []) or []):
        if not c.get("ready") and not c.get("state", {}).get("terminated", {}).get("reason") == "Completed":
            names.append(c["name"])
    for c in (st.get("containerStatuses", []) or []):
        if not c.get("ready"):
            names.append(c["name"])
    return names


def _scan_pods() -> dict | None:
    """Snapshot every pod in the namespace, classified for both status + doctor.

    Returns a dict with:
      rows      list of (name, phase, ready, restarts, age, note) for the table
      report    plain-text lines (same info) for a pi prompt
      main_bad  is hermes-0 itself unhealthy / missing
      dep_bad   names of unhealthy non-main (dependency) pods
      broken    the raw unhealthy pod objects (for targeted log pulls)
      bad       anything unhealthy at all
    Returns None if pods can't be read.
    """
    out = _capture(["kubectl", "get", "pods", "-n", _NS, "-o", "json"])
    try:
        items = json.loads(out).get("items", [])
    except json.JSONDecodeError:
        _err(f"could not read pods (kubectl said: {out.strip()[:200]})")
        return None
    if not items:
        _err(f"no pods in {_NS}")
        return None

    def _created(p):
        return p.get("metadata", {}).get("creationTimestamp", "")

    def _unhealthy(phase, ready, reason):
        got, want = ready.split("/")
        return phase not in ("Running", "Succeeded") or got != want or bool(reason)

    # Main pod first, then dependencies alphabetically.
    main = next((p for p in items if p["metadata"]["name"] == _POD), None)
    others = sorted((p for p in items if p["metadata"]["name"] != _POD),
                    key=lambda x: x["metadata"]["name"])
    ordered = ([main] if main else []) + others

    rows, report, broken, dep_bad = [], [], [], []
    bad = False
    main_bad = main is None
    if main is None:
        rows.append((_POD, "NOT FOUND", "0/0", "0", "?", "pod absent"))
        report.append(f"{_POD}: NOT FOUND")
        bad = True

    for p in ordered:
        name = p["metadata"]["name"]
        phase, ready, restarts, reason = _pod_summary(p)
        age = _age(_created(p))
        rows.append((name, phase, ready, str(restarts), age, reason or ""))
        report.append(f"{name}: {phase} (ready {ready}, {restarts} restarts, age {age})"
                      + (f" — {reason}" if reason else ""))
        if _unhealthy(phase, ready, reason):
            bad = True
            broken.append(p)
            if name == _POD:
                main_bad = True
            else:
                dep_bad.append(name)

    return {"rows": rows, "report": report, "main_bad": main_bad,
            "dep_bad": dep_bad, "broken": broken, "bad": bad}


def cmd_status(_args) -> int:
    """Pure status: print a table of every hermes pod. No side effects, no AI.

    Just observability — for the diagnose+fix flow use `hctl doctor`.
    """
    h = _scan_pods()
    if h is None:
        return 1
    headers = ("POD", "PHASE", "READY", "RESTARTS", "AGE", "NOTE")
    cols = [headers, *h["rows"]]
    widths = [max(len(str(r[i])) for r in cols) for i in range(len(headers))]
    for r in cols:
        print("  ".join(str(v).ljust(widths[i]) for i, v in enumerate(r)).rstrip(), flush=True)
    return 0


def _capture(cmd: list[str]) -> str:
    """Run cmd, return combined stdout+stderr; never raises."""
    r = subprocess.run(cmd, capture_output=True, text=True)
    return (r.stdout or "") + (r.stderr or "")


def _git_recent() -> str:
    """Recent commits touching the hermes chart/image — the usual 'what changed'."""
    return _capture(["git", "log", "--oneline", "-n", "15", "--",
                     "k8s/charts/hermes", "k8s/images/hermes"])


def _diagnostics_text() -> str:
    """Generic cluster context: pods, events, main-container logs."""
    return "\n\n".join([
        "### pods\n" + _capture(["kubectl", "get", "pods", "-n", _NS, "-o", "wide"]),
        "### events\n" + _capture(["kubectl", "get", "events", "-n", _NS, "--sort-by=.lastTimestamp"]),
        f"### logs ({_CONTAINER}, tail 200)\n" + _capture(
            ["kubectl", "logs", f"statefulset/{_STS}", "-n", _NS, "-c", _CONTAINER, "--tail=200"]),
    ])


def _pod_logs(pod: dict, containers: list[str]) -> str:
    name = pod["metadata"]["name"]
    chunks = []
    for c in containers:
        cur = _capture(["kubectl", "logs", name, "-n", _NS, "-c", c, "--tail=120"])
        prev = _capture(["kubectl", "logs", name, "-n", _NS, "-c", c, "--previous", "--tail=120"])
        chunks.append(f"#### {name}/{c} (current)\n{cur}\n#### {name}/{c} (previous)\n{prev}")
    return "\n\n".join(chunks)


def _build_incident_prompt(report, main_bad, dep_bad, broken) -> str:
    """Compose a layered prompt from what's actually broken."""
    layers = [
        "hermes is not fully up. Investigate what's broken: read the failing "
        "containers' logs below, cross-reference the recent git changes to the "
        "hermes chart/image, find the root cause, and fix it."
    ]
    if main_bad:
        layers.append(
            "The main agent pod (hermes-0) itself is not running — hermes is DOWN "
            "and user-facing. Prioritize getting hermes-0 healthy.")
    if dep_bad:
        layers.append(
            f"These hermes dependencies are unhealthy: {', '.join(dep_bad)}. "
            "A failing dependency can block or degrade the agent — determine "
            "whether it's the cause or a symptom.")

    logs = "\n\n".join(
        _pod_logs(p, _failing_containers(p)) for p in broken if _failing_containers(p))

    return "\n\n".join([
        "\n\n".join(layers),
        "## observed state\n" + "\n".join(report),
        "## recent git changes (hermes chart/image)\n" + _git_recent(),
        "## failing container logs\n" + (logs or "(no logs available)"),
    ])


def _open_pi(prompt: str) -> int:
    """Open a pi session seeded with the given prompt."""
    _log("starting pi session with hermes context (ctrl+c to skip)")
    return subprocess.run(["pi", prompt]).returncode


def cmd_doctor(args) -> int:
    """Open a pi session to diagnose AND fix hermes (active — mutates state).

    Named 'doctor' not 'investigate' on purpose: a doctor diagnoses AND treats.
    This goes and changes things (edits manifests, restarts pods, pushes fixes via pi), it is not a
    read-only look. `status` is the passive counterpart.

    Two modes, one command:
      - With free-text  (`hctl doctor telegram bot stopped replying`):
        the text is the lead symptom. We attach recent git history + full
        cluster diagnostics and let pi take it from there.
      - Without text: we scan every hermes pod, and only if something is
        actually unhealthy do we build a *layered* prompt — a global
        "find what's broken and fix it" instruction, plus a fragment when the
        main agent (hermes-0) is down, plus a fragment naming any unhealthy
        dependency, plus the failing containers' current+previous logs. If
        everything is healthy there's nothing to fix, so we say so and exit.

    Design choices:
      - The prompt is composed from observed state so pi gets a focused brief
        (agent-down vs dependency-down read differently) instead of a generic
        "something's wrong".
      - Logs are pulled only for failing containers to keep the prompt tight.
      - Git history is included because the usual root cause is a recent change
        to the hermes chart/image.
      - This is split from `status` on purpose: status is pure observability,
        doctor is the (heavier, interactive, state-changing) fix flow.
        Ctrl+C at the pi prompt cleanly aborts before anything is changed.
    """
    text = " ".join(getattr(args, "text", []) or []).strip()
    if text:
        prompt = "\n\n".join([
            f"there's something wrong with hermes, user says: {text}\n\ninvestigate and fix it.",
            "## recent git changes (hermes chart/image)\n" + _git_recent(),
            "## cluster state\n" + _diagnostics_text(),
        ])
        return _open_pi(prompt)

    h = _scan_pods()
    if h is None:
        return 1
    if not h["bad"]:
        _log("all pods healthy — nothing to fix (pass a description to dig in anyway)")
        return 0
    return _open_pi(_build_incident_prompt(
        h["report"], h["main_bad"], h["dep_bad"], h["broken"]))


def cmd_backup_now(_args) -> int:
    """Trigger an immediate off-cluster Longhorn backup of the state volume.

    The daily RecurringJob already backs this volume up at 02:00 UTC; this is
    for when you just changed something (e.g. re-paired WhatsApp) and don't
    want to wait. Snapshots the state PVC, then pushes that snapshot to the
    Longhorn backup target, blocking until it reports Completed.
    """
    vol = _capture(
        ["kubectl", "get", "pvc", _STATE_PVC, "-n", _NS,
         "-o", "jsonpath={.spec.volumeName}"]).strip()
    if not vol or vol.startswith("error") or " " in vol:
        _err(f"could not resolve Longhorn volume for PVC {_STATE_PVC} in {_NS}: {vol[:200]}")
        return 1
    name = "hctl-backup-" + datetime.datetime.now(datetime.timezone.utc).strftime("%Y%m%d-%H%M%S")
    _log(f"snapshotting volume {vol} (PVC {_STATE_PVC}) as {name}")
    snap = (
        "apiVersion: longhorn.io/v1beta2\n"
        "kind: Snapshot\n"
        f"metadata:\n  name: {name}\n  namespace: longhorn-system\n"
        f"spec:\n  volume: {vol}\n  createSnapshot: true\n"
    )
    subprocess.run(["kubectl", "create", "-f", "-"], input=snap, text=True, check=True)

    _log("waiting for snapshot to be ready")
    for _ in range(40):
        ready = _capture(
            ["kubectl", "get", "snapshots.longhorn.io", name, "-n", "longhorn-system",
             "-o", "jsonpath={.status.readyToUse}"]).strip()
        if ready == "true":
            break
        time.sleep(3)
    else:
        _err("snapshot did not become ready in time")
        return 1

    _log("pushing backup to the Longhorn backup target")
    bk = (
        "apiVersion: longhorn.io/v1beta2\n"
        "kind: Backup\n"
        f"metadata:\n  name: {name}\n  namespace: longhorn-system\n"
        f"  labels:\n    backup-volume: {vol}\n"
        f"spec:\n  snapshotName: {name}\n"
    )
    subprocess.run(["kubectl", "create", "-f", "-"], input=bk, text=True, check=True)

    for _ in range(150):
        state = _capture(
            ["kubectl", "get", "backups.longhorn.io", name, "-n", "longhorn-system",
             "-o", "jsonpath={.status.state}"]).strip()
        if state == "Completed":
            _log(f"backup {name} completed")
            return 0
        if state == "Error":
            err = _capture(
                ["kubectl", "get", "backups.longhorn.io", name, "-n", "longhorn-system",
                 "-o", "jsonpath={.status.error}"]).strip()
            _err(f"backup failed: {err}")
            return 1
        time.sleep(4)
    _err("backup did not complete in time (still running — check `kubectl -n longhorn-system get backups.longhorn.io`)")
    return 1


def cmd_refresh(_args) -> int:
    """Delete the env secret, restart the statefulset, and wait for ready."""
    _log(f"deleting secret {_SECRET} in {_NS} (ExternalSecret will recreate it)")
    _run(["kubectl", "delete", "secret", _SECRET, "-n", _NS, "--ignore-not-found"])
    _log(f"restarting statefulset {_STS} in {_NS}")
    _run(["kubectl", "rollout", "restart", f"statefulset/{_STS}", "-n", _NS])
    _log("watching rollout until ready")
    _run(["kubectl", "rollout", "status", f"statefulset/{_STS}", "-n", _NS])
    _log("done, hermes is ready")
    return 0


# ─────────────────────────────────────── argparse wiring ──

_EPILOG = """\
server commands (run INSIDE the container):
  auth login                       gh auth login + setup-git from env token
  op files sync                    download all attachments of a 1Password item
  repos clone                      clone every <user>/<name> into <dest>/<name>
  repos sync                       periodic + on-exit pull/commit/push loop
  backup                           periodic git backup of the HERMES_HOME allowlist
  restore                          seed an empty HERMES_HOME from the backup repo

client commands (run on your LOCAL machine, talk to the pod via kubectl):
  exec|hermes [args...]            run the hermes CLI inside the pod
  bash                             interactive bash shell in the pod
  status                           table of every hermes pod (pure status)
  doctor|fix [text]                open a pi session to diagnose AND fix (mutates state);
                                   text = lead symptom, else auto-detects what's broken
  refresh                          delete env secret, restart, wait for ready
  client backup                    trigger an immediate off-cluster Longhorn backup of the state volume

Run `hctl <command> --help` for per-command flags.
"""


def _build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="hctl",
        description="Hermes control CLI — a server side that runs in the container "
                    "and a client side that drives the pod from your local machine.",
        epilog=_EPILOG,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = p.add_subparsers(dest="cmd", required=True, metavar="<command>")

    # auth
    auth = sub.add_parser("auth").add_subparsers(dest="auth_cmd", required=True)
    auth_login = auth.add_parser("login", help="gh auth login + setup-git from env token")
    auth_login.set_defaults(func=cmd_auth_login)

    # op files sync
    op = sub.add_parser("op").add_subparsers(dest="op_cmd", required=True)
    op_files = op.add_parser("files", help="files helpers").add_subparsers(dest="op_files_cmd", required=True)
    op_files_sync = op_files.add_parser("sync", help="download all attachments of an op item")
    op_files_sync.add_argument("--host", default="", help="OP Connect host (default: $OP_CONNECT_HOST)")
    op_files_sync.add_argument("--vault", default="", help="vault name (default: $OP_VAULT)")
    op_files_sync.add_argument("--item", default="", help="item title (default: $OP_ITEM)")
    op_files_sync.add_argument("--dest", default="", help="output directory (default: $OP_DEST)")
    op_files_sync.add_argument("--token", default="", help="Connect token (testing only)")
    op_files_sync.add_argument("--token-file", default="", help="path to file containing Connect token")
    op_files_sync.add_argument("--connect-credentials-secret", default="",
                               help="NS/NAME[:KEY] of a kubectl-fetched secret holding the token")
    op_files_sync.set_defaults(func=cmd_op_files_sync)

    # repos
    repos = sub.add_parser("repos").add_subparsers(dest="repos_cmd", required=True)

    rc = repos.add_parser("clone", help="clone every <user>/<name> into <dest>/<name>")
    rc.add_argument("--user", required=True, help="github user/org")
    rc.add_argument("--repos", required=True, help="comma-separated list of repo names or name@branch")
    rc.add_argument("--branch", default="main", help="default branch (default: main); per-repo override via name@branch")
    rc.add_argument("--dest", default="/workdir", help="destination directory (default: /workdir)")
    rc.set_defaults(func=cmd_repos_clone)

    rs = repos.add_parser("sync", help="periodic + on-exit pull/commit/push loop")
    rs.add_argument("--dir", default="/workdir", help="root containing one repo per child dir")
    rs.add_argument("--interval", default="1h", help="duration between cycles (e.g. 30s, 5m, 1h)")
    rs.set_defaults(func=cmd_repos_sync)

    # backup / restore
    bk = sub.add_parser("backup")
    bk.add_argument("--user", required=True, help="github user/org owning the backup repo")
    bk.add_argument("--repo", required=True, help="backup repo name (private)")
    bk.add_argument("--branch", default="main", help="branch (default: main)")
    bk.add_argument("--home", default="", help="HERMES_HOME (default: $HERMES_HOME or /opt/data)")
    bk.add_argument("--dest", default="/backup", help="where to check out the backup repo")
    bk.add_argument("--interval", default="1h", help="duration between cycles (e.g. 30s, 5m, 1h)")
    bk.set_defaults(func=cmd_backup)

    rst = sub.add_parser("restore")
    rst.add_argument("--user", required=True, help="github user/org owning the backup repo")
    rst.add_argument("--repo", required=True, help="backup repo name (private)")
    rst.add_argument("--branch", default="main", help="branch (default: main)")
    rst.add_argument("--home", default="", help="HERMES_HOME (default: $HERMES_HOME or /opt/data)")
    rst.add_argument("--dest", default="/backup", help="where to check out the backup repo")
    rst.set_defaults(func=cmd_restore)

    # client (local machine → pod via kubectl)
    ex = sub.add_parser("exec", aliases=["hermes"])
    ex.add_argument("args", nargs=argparse.REMAINDER, help="args passed to `hermes`")
    ex.set_defaults(func=cmd_exec)

    bh = sub.add_parser("bash")
    bh.set_defaults(func=cmd_bash)

    st = sub.add_parser("status")
    st.set_defaults(func=cmd_status)

    rf = sub.add_parser("refresh")
    rf.set_defaults(func=cmd_refresh)

    client = sub.add_parser("client").add_subparsers(dest="client_cmd", required=True)
    client_backup = client.add_parser("backup", help="trigger an immediate off-cluster Longhorn backup of the state volume")
    client_backup.set_defaults(func=cmd_backup_now)

    inv = sub.add_parser("doctor", aliases=["fix"])
    inv.add_argument("text", nargs=argparse.REMAINDER, help="optional lead symptom")
    inv.set_defaults(func=cmd_doctor)

    return p


def main(argv: list[str] | None = None) -> int:
    parser = _build_parser()
    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    try:
        sys.exit(main())
    except subprocess.CalledProcessError as e:
        _err(f"{e}")
        sys.exit(e.returncode or 1)
    except Exception as e:  # noqa: BLE001
        _err(f"error: {e}")
        sys.exit(1)
