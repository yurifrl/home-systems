#!/usr/bin/env python3
"""Sync all file attachments of a 1Password item into a directory via the
1Password Connect REST API.

Dynamic by design: it lists whatever files the item currently has and writes
each one out by its own name. No filenames are configured anywhere.

Config via env:
  OP_CONNECT_HOST   e.g. http://onepassword-connect.1password.svc.cluster.local:8080
  OP_CONNECT_TOKEN  Connect access token (Bearer)
  OP_VAULT          vault name (e.g. kubernetes)
  OP_ITEM           item title (e.g. hermes-files)
  OP_DEST           destination directory (e.g. /opt/data/files)

Exit 0 on success or soft-skip (missing token/vault/item); non-zero only on
unexpected API/IO errors.
"""
import json
import os
import sys
import urllib.parse
import urllib.request


def _env(name):
    v = os.environ.get(name, "").strip()
    return v


def main():
    host = _env("OP_CONNECT_HOST").rstrip("/")
    token = _env("OP_CONNECT_TOKEN")
    vault = _env("OP_VAULT")
    item = _env("OP_ITEM")
    dest = _env("OP_DEST")

    if not all([host, vault, item, dest]):
        print("op-files: missing OP_CONNECT_HOST/OP_VAULT/OP_ITEM/OP_DEST; skipping", file=sys.stderr)
        return 0
    if not token:
        print("op-files: no OP_CONNECT_TOKEN; skipping", file=sys.stderr)
        return 0

    def get(path, raw=False):
        req = urllib.request.Request(host + path, headers={"Authorization": "Bearer " + token})
        data = urllib.request.urlopen(req, timeout=20).read()
        return data if raw else json.loads(data)

    vaults = get("/v1/vaults")
    vid = next((v["id"] for v in vaults if v.get("name") == vault), None)
    if not vid:
        print("op-files: vault %r not found; skipping" % vault, file=sys.stderr)
        return 0

    q = urllib.parse.quote('title eq "%s"' % item)
    items = get("/v1/vaults/%s/items?filter=%s" % (vid, q))
    if not items:
        print("op-files: item %r not found in vault %r; skipping" % (item, vault), file=sys.stderr)
        return 0
    iid = items[0]["id"]

    full = get("/v1/vaults/%s/items/%s" % (vid, iid))
    files = full.get("files", []) or []

    os.makedirs(dest, exist_ok=True)
    written = 0
    for f in files:
        name = os.path.basename(f.get("name", "")).strip()
        if not name:
            continue
        cp = f.get("content_path") or ("/v1/vaults/%s/items/%s/files/%s/content" % (vid, iid, f["id"]))
        blob = get(cp, raw=True)
        out = os.path.join(dest, name)
        with open(out, "wb") as fh:
            fh.write(blob)
        os.chmod(out, 0o600)
        print("op-files: wrote %s (%d bytes)" % (name, len(blob)))
        written += 1

    print("op-files: done, %d file(s) from item %r" % (written, item))
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except Exception as e:  # noqa: BLE001
        print("op-files: error: %s" % e, file=sys.stderr)
        sys.exit(1)
